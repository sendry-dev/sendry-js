{
  "name": "sendry-sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for the Sendry email API",
  "author": "Sendry",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "bun-types": "latest"
  },
  "keywords": [
    "email",
    "sendry",
    "email-api",
    "transactional-email",
    "typescript",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sendry-dev/sendry-js"
  },
  "homepage": "https://sendry.online",
  "bugs": {
    "url": "https://github.com/sendry-dev/sendry-js/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
